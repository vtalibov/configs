; Vladimir's polybar config
;

[colors]
background = #282828
background-alt = #555048
foreground = #ebdbb2
yellow = #d79921
red = #cc241d
red-alt = #fb4934
grey = #928374 

[bar/example]
width = 100%
height = 27
fixed-center = false

background = ${colors.background}
foreground = ${colors.foreground}

line-size = 3
line-color = ${colors.yellow}

border-size = 0
border-color = ${colors.grey}

padding-left = 2
padding-right = 2

module-margin-left = 1
module-margin-right = 1

font-0 = mixed:pixelsize=12;1
font-1 = mono:pixelsize=16;1
font-2 = mono:pixelsize=18;5

modules-left = menu-apps bspwm
modules-right = cpu filesystem memory wlan battery xkeyboard weather date

tray-position = right
tray-padding = 2

wm-restack = bspwm

cursor-click = pointer
cursor-scroll = ns-resize

[module/menu-apps]

type = custom/menu
label-open = "%{F#cc241d}%{F-}"
label-close = "%{F#fb4934}%{F-}"
label-open-font = 3
label-close-font = 3
label-separator = "  "

menu-0-0 = "Suspend"
menu-0-0-exec = systemctl suspend
menu-0-1 = "Reboot"
menu-0-1-exec = systemctl reboot
menu-0-2 = "Power off"
menu-0-2-exec = systemctl poweroff

[module/xkeyboard]

type = internal/xkeyboard
blacklist-0 = num lock

label-layout = %layout%

label-indicator-padding = 2
label-indicator-margin = 1
label-indicator-background = ${colors.red}

[module/filesystem]

type = internal/fs
interval = 25

mount-0 = /

label-mounted = %{F#ffb52a} %{F-} %free%
label-unmounted = %mountpoint% not mounted
label-unmounted-foreground = ${colors.foreground-alt}#!/usr/bin/env bash

[module/bspwm]

type = internal/bspwm

label-focused = %index%
label-focused-background = ${colors.background-alt}
label-focused-underline= ${colors.yellow}
label-focused-padding = 2

label-occupied = %index%
label-occupied-padding = 1

label-urgent = %index%!
label-urgent-background = ${colors.red-alt}
label-urgent-padding = 1

label-empty = %index%
label-empty-foreground = ${colors.grey}
label-empty-padding = 1

[module/cpu]
type = internal/cpu
interval = 2
format-prefix = " "
format-prefix-foreground = ${colors.yellow}
label = %percentage:2%%

[module/memory]
type = internal/memory
interval = 2
format-prefix = "舘  "
format-prefix-foreground = ${colors.yellow}
label = %percentage_used%%

[module/wlan]
type = internal/network
interface = wlp4s0
interval = 3.0

format-connected = <ramp-signal> <label-connected>
label-connected = %essid%

format-disconnected =

ramp-signal-0 = (1)
ramp-signal-1 = (2)
ramp-signal-2 = (3)
ramp-signal-3 = (4)
ramp-signal-4 = (5)
ramp-signal-foreground = ${colors.grey}

[module/date]
type = internal/date
interval = 5

date = "w:%V %m/%d"
date-alt = "%m/%d"

time = %H:%M
time-alt = %H:%M

format-prefix = "  "
format-prefix-foreground = ${colors.yellow}

label = %date%, %time% 

[module/battery]

type = internal/battery
battery = BAT1
adapter = AC  
full-at = 98  
pol-interval = 5
              
format-charging = %{F#d79921}AC%{F-} <label-charging>

format-discharging = %{F#cc241d}BAT%{F-} <label-discharging> 
format-full-prefix = "FULL "
format-full-prefix-foreground = ${colors.grey}
;format-full-underline = ${self.format-charging-underline}

[settings]
screenchange-reload = true
;compositing-background = xor
;compositing-background = screen
;compositing-foreground = source
;compositing-border = over
;pseudo-transparency = false

[global/wm]
margin-top = 2
margin-bottom = 2

; vim:ft=dosini

; Vladimir's custom modules
[module/weather]
type = custom/script
interval = 1800
format-prefix = "﨎 "
format-prefix-foreground = ${colors.primary}
exec = weather $CITY
